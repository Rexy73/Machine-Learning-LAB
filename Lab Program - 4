#Lab Program 4
import pandas as pd

# Function to explore CSV files
def explore_csv(file_path):
    print(f"\nExploring CSV file: {file_path}")
    
    # Loading dataset
    data_csv = pd.read_csv(file_path)
    
    print("\nFirst 5 rows:\n", data_csv.head())
    print("\nData types:\n", data_csv.dtypes)
    print("\nShape of the dataset:\n", data_csv.shape)
    print("\nColumns of dataset:\n", data_csv.columns)
    print("\nSummary statistics:\n", data_csv.describe())
    print("\nDataFrame info:")
    data_csv.info()

# Function to explore Excel files
def explore_excel(file_path):
    print(f"\nExploring Excel file: {file_path}")
    
    # Loading dataset
    data_excel = pd.read_excel(file_path)
    
    print("\nFirst 5 rows:\n", data_excel.head())
    print("\nData types:\n", data_excel.dtypes)
    print("\nShape of the dataset:\n", data_excel.shape)
    print("\nColumns of dataset:\n", data_excel.columns)
    print("\nSummary statistics:\n", data_excel.describe())
    print("\nDataFrame info:")
    data_excel.info()

# Main execution
# csv_file_path = 'iris.csv'
# excel_file_path = 'iris.xlsx'

explore_csv("iris.csv")
explore_excel("iris.xlsx")
